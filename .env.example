# AIOS env registry — names + purpose ONLY (no secret values here).
# Real values go in .env.local (gitignored). This file is the committed
# "name -> purpose" mapping so we know which secret to use where.
#
# Usage:
#  - Flow ba_http nodes / STANDARD tool headers reference these by name, e.g.
#    Authorization: Bearer ${AIOS_N8N_WEBHOOK_TOKEN}
#  - The agent never reads this file. Local scripts do:
#    - smoke-test a webhook:  node scripts/smoke-webhook.mjs --url <url> --var <NAME>
#    - reconcile a FLOW push: node scripts/reconcile-flow.mjs --flow <path>
#  - At push time the script substitutes the value and ENCRYPTS it; RecallSync
#    stores ciphertext and decrypts at runtime (never committed to Git).

# RecallSync MCP api key (for the primary MCP). All RecallSync operations go
# through MCP — there is intentionally no REST URL here.
RECALL_API_KEY=

# Default bearer token for FunAway / n8n webhooks.
# Auth scheme: Header  Authorization: Bearer <token>
AIOS_N8N_WEBHOOK_TOKEN=

# Bearer token for the Brain Instagram qualification webhook (n8n).
# Auth scheme: Header  Authorization: Bearer <token>
AIOS_N8N_WEBHOOK_TOKEN_V2=

# Symmetric key for header-secret encryption (AES-256-CBC).
# MUST be byte-identical to recallsync-app's ENCRYPTION_KEY, otherwise ciphertext
# minted here (scripts/secret.mjs) won't decrypt on the runtime side.
# Used so the repo/agent only ever handle CIPHERTEXT, never plaintext tokens.
# Transitional: while this lives in .env.local it is readable locally; the plan
# is to rotate it and move it server-side (.env) so the agent can't read it.
ENCRYPTION_KEY=

# --- Local Postgres (docker-compose.yml) — lead-factory staging DB ---
# Consumed by docker compose for variable substitution. Local-dev defaults are
# inlined in docker-compose.yml, so these only need setting to override them.
# For docker compose to auto-load these, put the real values in a gitignored
# `.env` file in the repo root (compose reads `.env`, NOT `.env.local`).
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=

# Prisma connection string for the local Postgres above (prisma.config.ts +
# lib/prisma.ts read this). With the docker-compose defaults it is:
#   postgresql://aios:aios_local_dev@localhost:5433/aios_leads
# Put the real value in the gitignored `.env` (compose + Prisma both read `.env`).
DATABASE_URL=

# --- crawl4ai (docker-compose.yml) — JS-rendering crawler on :11235 ---
# Used to scrape JS-gated pages (Facebook/social profiles) where a plain HTTP
# fetch only sees a login/pre-render shell. CRAWL4AI_API_TOKEN is optional; when
# set, requests must send `Authorization: Bearer <token>`.
CRAWL4AI_PORT=
CRAWL4AI_API_TOKEN=
# Base URL the cursor-enrichment agent uses to reach crawl4ai. Defaults to
# http://localhost:11235 (the docker-compose service). Set to empty to stop
# telling the enrichment agent the crawler exists.
CRAWL4AI_URL=

# --- GM Scraper / gmaps-harvester (docker-compose.yml on :5071) ---
# Playwright service that scrapes Google Maps for GM Scraper queries.
GMAPS_HARVESTER_URL=
GMAPS_HARVESTER_PORT=
# When true, CRM uses stub listings (no harvester needed). When "fallback",
# stub is used only if the harvester request fails.
GMAPS_HARVESTER_STUB=

# --- Local email verifier/finder (recall-email-finder Flask app on :5050) ---
# Base URL the CRM route handlers call to verify/find emails. Defaults to
# http://localhost:5050 when unset. Start it: `venv/bin/python app.py` from the
# recall-email-finder repo. Used by app/api/contacts/[id]/verify-email.
EMAIL_VERIFIER_URL=

# --- Cursor enrichment service (services/cursor-enrichment on :5070) ---
# The service spawns cursor-agent with web search to enrich company firmographics
# and signals, then calls back into the CRM. CURSOR_API_KEY lives in the real
# root .env and is read by the spawned cursor-agent process.
CURSOR_ENRICHMENT_URL=
CURSOR_ENRICHMENT_PORT=
ENRICHMENT_CALLBACK_SECRET=
ENRICH_CONCURRENCY=
ENRICH_AGENT_TIMEOUT_MS=
CURSOR_AGENT_BIN=
CURSOR_AGENT_CWD=
CURSOR_AGENT_MODEL=
CURSOR_AGENT_AUTO_APPROVE=
CURSOR_API_KEY=

# --- Optional external cron trigger (app/api/cron/process) ---
# Only needed if an OUTSIDE scheduler hits POST /api/cron/process manually.
# The dashboard Cronjobs page uses the in-app scheduler instead (no secret needed).
#   Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# --- Telegram bridge (telegram-bridge/, npm run bridge) ---
# Bot token from @BotFather. NEVER commit the real value.
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user ids allowed to DM the bot.
TELEGRAM_ALLOWED_USER_IDS=
# Optional override for RecallSync MCP URL (bridge renders .cursor/mcp.json).
# RECALLSYNC_MCP_URL=https://mcp.recallsync.com/mcp
