# AIOS env registry — names + purpose ONLY (no secret values here).
# Real values go in .env.local (gitignored). This file is the committed
# "name -> purpose" mapping so we know which secret to use where.
#
# Usage:
#  - Flow ba_http nodes / STANDARD tool headers reference these by name, e.g.
#    Authorization: Bearer ${AIOS_N8N_WEBHOOK_TOKEN}
#  - The agent never reads this file. Local scripts do:
#    - smoke-test a webhook:  node scripts/smoke-webhook.mjs --url <url> --var <NAME>
#    - reconcile a FLOW push: node scripts/reconcile-flow.mjs --flow <path>
#  - At push time the script substitutes the value and ENCRYPTS it; RecallSync
#    stores ciphertext and decrypts at runtime (never committed to Git).

# RecallSync MCP api key (for the primary MCP). All RecallSync operations go
# through MCP — there is intentionally no REST URL here.
RECALL_API_KEY=

# Default bearer token for FunAway / n8n webhooks.
# Auth scheme: Header  Authorization: Bearer <token>
AIOS_N8N_WEBHOOK_TOKEN=

# Bearer token for the Brain Instagram qualification webhook (n8n).
# Auth scheme: Header  Authorization: Bearer <token>
AIOS_N8N_WEBHOOK_TOKEN_V2=

# Symmetric key for header-secret encryption (AES-256-CBC).
# MUST be byte-identical to recallsync-app's ENCRYPTION_KEY, otherwise ciphertext
# minted here (scripts/secret.mjs) won't decrypt on the runtime side.
# Used so the repo/agent only ever handle CIPHERTEXT, never plaintext tokens.
# Transitional: while this lives in .env.local it is readable locally; the plan
# is to rotate it and move it server-side (.env) so the agent can't read it.
ENCRYPTION_KEY=

# --- Telegram bridge (telegram-bridge/, npm run bridge) ---
# Bot token from @BotFather. NEVER commit the real value.
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user ids allowed to DM the bot.
TELEGRAM_ALLOWED_USER_IDS=
# Optional override for RecallSync MCP URL (bridge renders .cursor/mcp.json).
# RECALLSYNC_MCP_URL=https://mcp.recallsync.com/mcp
